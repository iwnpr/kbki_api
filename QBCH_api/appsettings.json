{
  "Logging": {
    "LogLevel": {
      "Default": "Error",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Features": {
    "SetDefaultApiVersion": true,
    "DefaultApiVersion": 1.3
  },
  "Paths": {
    "Xsd": "xsd"
  },
  "FeatureFlags": {
    "DisableOldApiVersion_1_3": false
  }
}
