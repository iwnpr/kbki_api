      "dlput": [ "qcb_put.xsd" ]
    },
    "3": {
      "dlrequest": [ "qcb_request.xsd" ],
      "dlput": [ "qcb_put.xsd" ]
    }
  },
  "FeatureFlags": {
    "DisableOldApiVersion_1_3": false
  }
}
